# Copy this file to .env.local (never commit .env.local to git)
# Get these values from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Lambda report generator endpoint (set after deploying to AWS)
VITE_LAMBDA_URL=https://your-lambda-url.lambda-url.ap-northeast-1.on.aws
